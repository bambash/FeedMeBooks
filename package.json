{
  "name": "feedmebooks",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate:fixtures": "node scripts/generate-fixtures.mjs"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-expo|expo-modules-core|expo-asset|expo-constants|expo-file-system|expo-font|expo-application|expo-av|expo-clipboard|expo-document-picker|expo-image|expo-image-picker|expo-linking|expo-router|expo-splash-screen|expo-status-bar|expo|@expo|react-native|@react-native|whisper\\.rn)/)"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.28",
    "expo-av": "~14.0.7",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-image": "~1.12.15",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.23",
    "expo-splash-screen": "~0.27.6",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-blob-util": "^0.24.7",
    "react-native-pdf": "6.7.4",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-webview": "13.8.6",
    "whisper.rn": "^0.5.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.2.45",
    "jest": "^30.3.0",
    "jest-expo": "~51.0.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
